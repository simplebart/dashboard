# Vul deze in met de gegevens uit je Supabase-project (Project Settings → API).
# Zonder deze twee regels draait het dashboard in lokale modus: geen login,
# alles blijft in je browser.
NEXT_PUBLIC_SUPABASE_URL=https://jouwproject.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=jouw-anon-key

# Alleen nodig voor de live agendafeed naar Apple Agenda.
# Deze sleutel is geheim: zet hem in Vercel, nooit in de browser of op GitHub.
SUPABASE_SERVICE_ROLE_KEY=jouw-service-role-key
